/**
 * Domain Manager v3 - Cloudflare Worker
 * 修复版：更好的错误处理 + KV 安全检查
 */

export default {
  async fetch(request, env, ctx) {
    try {
      const url = new URL(request.url);
      const path = url.pathname;

      // 健康检查（无需鉴权，无需KV）
      if (path === '/api/health') {
        const kvOk = !!env.KV;
        return jsonRes({ ok: true, kv: kvOk, msg: kvOk ? 'KV已绑定' : '⚠️ KV未绑定，请在Worker设置中绑定KV Namespace' });
      }

      // Telegram webhook 不鉴权
      if (path === '/api/telegram/webhook' && request.method === 'POST') {
        return handleTelegramWebhook(request, env);
      }

      // 根路径返回HTML
      if (path === '/' || path === '/index.html') {
        return serveHTML();
      }

      // API 鉴权
      if (path.startsWith('/api/')) {
        const auth = await authenticate(request, env);
        if (!auth.ok) return auth.response;
        return handleAPI(request, env, path);
      }

      return new Response('Not Found', { status: 404 });
    } catch (e) {
      return jsonRes({ error: '服务器错误: ' + e.message }, 500);
    }
  },

  async scheduled(event, env, ctx) {
    ctx.waitUntil(runDailyCheck(env));
  },
};

// ─── KV 安全读写 ────────────────────────────────────────────────────────────

async function kvGet(env, key, fallback = '[]') {
  if (!env.KV) return fallback;
  try { return (await env.KV.get(key)) || fallback; } catch { return fallback; }
}

async function kvPut(env, key, value) {
  if (!env.KV) throw new Error('KV Namespace 未绑定！请在 Worker Settings → Bindings 中绑定 KV，变量名填 KV');
  await env.KV.put(key, value);
}

async function getList(env, key) {
  return JSON.parse(await kvGet(env, key, '[]'));
}

// ─── Auth ───────────────────────────────────────────────────────────────────

async function authenticate(request, env) {
  if (request.method === 'POST' && new URL(request.url).pathname === '/api/login') {
    return { ok: true };
  }
  const pw = env.ADMIN_PASSWORD || 'admin123';
  const cookie = request.headers.get('Cookie') || '';
  const token = extractCookie(cookie, 'dm_token');
  if (token && await verifyToken(token, pw)) return { ok: true };
  return { ok: false, response: jsonRes({ error: 'Unauthorized' }, 401) };
}

async function verifyToken(token, pw) {
  try {
    const [p, s] = token.split('.');
    return s === await hmacSign(p, pw) && Date.now() < JSON.parse(atob(p)).exp;
  } catch { return false; }
}

async function createToken(pw) {
  const p = btoa(JSON.stringify({ exp: Date.now() + 86400000 * 7 }));
  return p + '.' + await hmacSign(p, pw);
}

async function hmacSign(data, key) {
  const enc = new TextEncoder();
  const k = await crypto.subtle.importKey('raw', enc.encode(key), { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
  const s = await crypto.subtle.sign('HMAC', k, enc.encode(data));
  return btoa(String.fromCharCode(...new Uint8Array(s)));
}

function extractCookie(str, name) {
  const m = str.match(new RegExp('(?:^|;\\s*)' + name + '=([^;]*)'));
  return m ? m[1] : null;
}

// ─── API Router ──────────────────────────────────────────────────────────────

async function handleAPI(request, env, path) {
  const m = request.method;
  try {
    // 登录/登出
    if (path === '/api/login' && m === 'POST') {
      const body = await request.json().catch(() => ({}));
      const pw = env.ADMIN_PASSWORD || 'admin123';
      if (!body.password || body.password !== pw) return jsonRes({ error: '密码错误' }, 401);
      const token = await createToken(pw);
      return new Response(JSON.stringify({ ok: true }), {
        headers: {
          'Content-Type': 'application/json',
          'Set-Cookie': 'dm_token=' + token + '; Path=/; HttpOnly; SameSite=Strict; Max-Age=604800',
        },
      });
    }
    if (path === '/api/logout' && m === 'POST') {
      return new Response(JSON.stringify({ ok: true }), {
        headers: { 'Content-Type': 'application/json', 'Set-Cookie': 'dm_token=; Path=/; HttpOnly; Max-Age=0' },
      });
    }

    // 统计
    if (path === '/api/stats' && m === 'GET') return getStats(env);

    // 域名
    if (path === '/api/domains') {
      if (m === 'GET') return getDomains(env);
      if (m === 'POST') return addDomain(await request.json(), env);
    }
    const domId = path.match(/^\/api\/domains\/(.+)$/)?.[1];
    if (domId) {
      if (m === 'PUT') return updateDomain(domId, await request.json(), env);
      if (m === 'DELETE') return deleteDomainById(domId, env);
    }

    // 账号
    if (path === '/api/accounts') {
      if (m === 'GET') return jsonRes(await getList(env, 'accounts'));
      if (m === 'POST') return addAccount(await request.json(), env);
    }
    const accId = path.match(/^\/api\/accounts\/(.+)$/)?.[1];
    if (accId) {
      if (m === 'PUT') return updateAccount(accId, await request.json(), env);
      if (m === 'DELETE') return deleteAccountById(accId, env);
    }

    // Cloudflare 账号
    if (path === '/api/cf-accounts') {
      if (m === 'GET') return getCFAccounts(env);
      if (m === 'POST') return addCFAccount(await request.json(), env);
    }
    const cfId = path.match(/^\/api\/cf-accounts\/(.+)$/)?.[1];
    if (cfId && m === 'DELETE') return deleteCFAccountById(cfId, env);

    // 同步
    if (path === '/api/cf-preview' && m === 'POST') return previewCF(await request.json(), env);
    if (path === '/api/cf-sync' && m === 'POST') return syncCF(await request.json(), env);

    // Telegram
    if (path === '/api/telegram') {
      if (m === 'GET') return getTgConfig(env);
      if (m === 'POST') return saveTgConfig(await request.json(), env);
    }

    // 手动检查
    if (path === '/api/check' && m === 'POST') {
      await runDailyCheck(env);
      return jsonRes({ ok: true, msg: '检查完成，如有到期域名已发送通知' });
    }

    return jsonRes({ error: '接口不存在' }, 404);
  } catch (e) {
    console.error(e);
    return jsonRes({ error: e.message }, 500);
  }
}

// ─── 域名 ─────────────────────────────────────────────────────────────────────

async function getDomains(env) {
  const [domains, accounts, cfAccounts] = await Promise.all([
    getList(env, 'domains'),
    getList(env, 'accounts'),
    getList(env, 'cf_accounts'),
  ]);
  const nameMap = Object.fromEntries([...accounts, ...cfAccounts].map(a => [a.id, a.name]));
  return jsonRes(
    domains
      .map(d => ({ ...d, accountName: nameMap[d.accountId] || '—', daysLeft: daysUntil(d.expiryDate) }))
      .sort((a, b) => a.daysLeft - b.daysLeft)
  );
}

async function addDomain(body, env) {
  if (!body.name) return jsonRes({ error: '域名为必填项' }, 400);
  if (!body.expiryDate) return jsonRes({ error: '到期日期为必填项' }, 400);
  const domains = await getList(env, 'domains');
  const d = {
    id: crypto.randomUUID(),
    name: body.name.trim().toLowerCase(),
    accountId: body.accountId || '',
    registrar: body.registrar || '',
    registrarUrl: body.registrarUrl || '',
    registeredAt: body.registeredAt || '',
    expiryDate: body.expiryDate,
    autoRenew: !!body.autoRenew,
    reminderDays: body.reminderDays || [1, 7, 30],
    notes: body.notes || '',
    source: body.source || 'manual',
    createdAt: new Date().toISOString(),
  };
  domains.push(d);
  await kvPut(env, 'domains', JSON.stringify(domains));
  return jsonRes(d);
}

async function updateDomain(id, body, env) {
  const domains = await getList(env, 'domains');
  const i = domains.findIndex(d => d.id === id);
  if (i < 0) return jsonRes({ error: '域名不存在' }, 404);
  domains[i] = { ...domains[i], ...body, id, updatedAt: new Date().toISOString() };
  await kvPut(env, 'domains', JSON.stringify(domains));
  return jsonRes(domains[i]);
}

async function deleteDomainById(id, env) {
  const domains = await getList(env, 'domains');
  await kvPut(env, 'domains', JSON.stringify(domains.filter(d => d.id !== id)));
  return jsonRes({ ok: true });
}

// ─── 账号 ─────────────────────────────────────────────────────────────────────

async function addAccount(body, env) {
  if (!body.name) return jsonRes({ error: '账号名称为必填项' }, 400);
  const accounts = await getList(env, 'accounts');
  const a = { id: crypto.randomUUID(), name: body.name.trim(), registrar: body.registrar || '', email: body.email || '', loginUrl: body.loginUrl || '', notes: body.notes || '', createdAt: new Date().toISOString() };
  accounts.push(a);
  await kvPut(env, 'accounts', JSON.stringify(accounts));
  return jsonRes(a);
}

async function updateAccount(id, body, env) {
  const accounts = await getList(env, 'accounts');
  const i = accounts.findIndex(a => a.id === id);
  if (i < 0) return jsonRes({ error: '账号不存在' }, 404);
  accounts[i] = { ...accounts[i], ...body, id };
  await kvPut(env, 'accounts', JSON.stringify(accounts));
  return jsonRes(accounts[i]);
}

async function deleteAccountById(id, env) {
  const accounts = await getList(env, 'accounts');
  await kvPut(env, 'accounts', JSON.stringify(accounts.filter(a => a.id !== id)));
  return jsonRes({ ok: true });
}

// ─── Cloudflare 账号 ──────────────────────────────────────────────────────────

async function getCFAccounts(env) {
  const list = await getList(env, 'cf_accounts');
  return jsonRes(list.map(a => ({ ...a, apiToken: a.apiToken ? '***已配置***' : '' })));
}

async function addCFAccount(body, env) {
  if (!body.name || !body.apiToken) return jsonRes({ error: '名称和 API Token 为必填项' }, 400);
  const verify = await cfAPI('/accounts?per_page=1', body.apiToken);
  if (!verify.success) {
    const msg = verify.errors?.[0]?.message || '验证失败，请检查 Token 是否有读取权限';
    return jsonRes({ error: 'API Token 无效: ' + msg }, 400);
  }
  const accounts = await getList(env, 'cf_accounts');
  const a = {
    id: crypto.randomUUID(),
    name: body.name.trim(),
    apiToken: body.apiToken.trim(),
    cfAccountId: verify.result?.[0]?.id || '',
    cfAccountName: verify.result?.[0]?.name || '',
    type: 'cloudflare',
    createdAt: new Date().toISOString(),
  };
  accounts.push(a);
  await kvPut(env, 'cf_accounts', JSON.stringify(accounts));
  return jsonRes({ ...a, apiToken: '***已配置***' });
}

async function deleteCFAccountById(id, env) {
  const list = await getList(env, 'cf_accounts');
  await kvPut(env, 'cf_accounts', JSON.stringify(list.filter(a => a.id !== id)));
  return jsonRes({ ok: true });
}

async function previewCF(body, env) {
  const cfAccounts = await getList(env, 'cf_accounts');
  const cf = cfAccounts.find(a => a.id === body.cfAccountId);
  if (!cf) return jsonRes({ error: '找不到该账号' }, 404);
  const result = await fetchAllCFDomains(cf);
  if (!result.ok) return jsonRes({ error: result.error }, 400);
  const existing = new Set((await getList(env, 'domains')).map(d => d.name));
  return jsonRes({
    domains: result.domains.map(d => ({ ...d, exists: existing.has(d.name) })),
    total: result.domains.length,
    newCount: result.domains.filter(d => !existing.has(d.name)).length,
  });
}

async function syncCF(body, env) {
  const cfAccounts = await getList(env, 'cf_accounts');
  const cf = cfAccounts.find(a => a.id === body.cfAccountId);
  if (!cf) return jsonRes({ error: '找不到该账号' }, 404);
  const result = await fetchAllCFDomains(cf);
  if (!result.ok) return jsonRes({ error: result.error }, 400);
  const domains = await getList(env, 'domains');
  const nameMap = new Map(domains.map((d, i) => [d.name, i]));
  let added = 0, updated = 0, skipped = 0;
  for (const d of result.domains) {
    if (nameMap.has(d.name)) {
      if (body.mode === 'all') {
        const i = nameMap.get(d.name);
        domains[i] = { ...domains[i], expiryDate: d.expiryDate || domains[i].expiryDate, autoRenew: d.autoRenew, updatedAt: new Date().toISOString(), source: d.source };
        updated++;
      } else { skipped++; }
    } else {
      domains.push({ id: crypto.randomUUID(), name: d.name, accountId: cf.id, registrar: 'Cloudflare', registrarUrl: 'https://dash.cloudflare.com/' + cf.cfAccountId + '/domains', registeredAt: d.registeredAt, expiryDate: d.expiryDate, autoRenew: d.autoRenew, reminderDays: [1, 7, 30], notes: '', source: d.source, createdAt: new Date().toISOString() });
      added++;
    }
  }
  await kvPut(env, 'domains', JSON.stringify(domains));
  return jsonRes({ ok: true, added, updated, skipped, total: result.domains.length });
}

async function fetchAllCFDomains(cf) {
  try {
    const domains = [];
    // 通过 Registrar API 获取（有完整到期时间）
    if (cf.cfAccountId) {
      const reg = await cfAPI('/accounts/' + cf.cfAccountId + '/registrar/domains?per_page=200', cf.apiToken);
      if (reg.success) {
        for (const d of reg.result || []) {
          domains.push({ name: d.name, registeredAt: (d.created_at || '').split('T')[0], expiryDate: (d.expires_at || '').split('T')[0], autoRenew: !!d.auto_renew, source: 'cf_registrar' });
        }
      }
    }
    // 通过 Zones API 获取托管域名
    const zones = await cfAPI('/zones?per_page=200&status=active', cf.apiToken);
    if (zones.success) {
      const existing = new Set(domains.map(d => d.name));
      for (const z of zones.result || []) {
        if (!existing.has(z.name)) {
          domains.push({ name: z.name, registeredAt: (z.created_on || '').split('T')[0], expiryDate: '', autoRenew: false, source: 'cf_zone' });
        }
      }
    }
    if (!domains.length) return { ok: false, error: '未找到任何域名。请确认 Token 拥有 Zone:Read 和 Account:Read 权限' };
    return { ok: true, domains };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

async function cfAPI(endpoint, token) {
  const r = await fetch('https://api.cloudflare.com/client/v4' + endpoint, {
    headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
  });
  return r.json();
}

// ─── 统计 ─────────────────────────────────────────────────────────────────────

async function getStats(env) {
  const [domains, accounts, cfAccounts] = await Promise.all([
    getList(env, 'domains'),
    getList(env, 'accounts'),
    getList(env, 'cf_accounts'),
  ]);
  const kvOk = !!env.KV;
  return jsonRes({
    ok: true,
    kvBound: kvOk,
    total: domains.length,
    accounts: accounts.length + cfAccounts.length,
    cfDomains: domains.filter(d => d.source && d.source.startsWith('cf')).length,
    expired: domains.filter(d => daysUntil(d.expiryDate) < 0).length,
    expiring7: domains.filter(d => { const x = daysUntil(d.expiryDate); return x >= 0 && x <= 7; }).length,
    expiring30: domains.filter(d => { const x = daysUntil(d.expiryDate); return x >= 0 && x <= 30; }).length,
    autoRenew: domains.filter(d => d.autoRenew).length,
  });
}

// ─── Telegram ─────────────────────────────────────────────────────────────────

async function getTgConfig(env) {
  const c = JSON.parse(await kvGet(env, 'telegram_config', '{}'));
  return jsonRes({ chatId: c.chatId || '', botToken: c.botToken ? '***已配置***' : '' });
}

async function saveTgConfig(body, env) {
  const existing = JSON.parse(await kvGet(env, 'telegram_config', '{}'));
  const c = { ...existing, chatId: body.chatId || existing.chatId || '' };
  if (body.botToken && body.botToken !== '***已配置***') c.botToken = body.botToken;
  await kvPut(env, 'telegram_config', JSON.stringify(c));
  return jsonRes({ ok: true });
}

async function handleTelegramWebhook(request, env) {
  const update = await request.json().catch(() => ({}));
  const msg = update.message;
  if (!msg) return jsonRes({ ok: true });
  const chatId = msg.chat.id;
  const text = (msg.text || '').trim();
  const c = JSON.parse(await kvGet(env, 'telegram_config', '{}'));
  if (text === '/start') {
    await tgSend(c.botToken, chatId, '🌐 *域名管理机器人*\n\n你的 Chat ID 是: `' + chatId + '`\n\n命令:\n/domains — 所有域名\n/expiring — 30天内到期\n/check — 立即检查');
  } else if (text === '/domains') {
    const domains = await getList(env, 'domains');
    const lines = domains.sort((a, b) => daysUntil(a.expiryDate) - daysUntil(b.expiryDate)).map(d => statusEmoji(daysUntil(d.expiryDate)) + ' `' + d.name + '` — ' + daysLeft(d.expiryDate)).join('\n');
    await tgSend(c.botToken, chatId, '🌐 *所有域名*\n\n' + (lines || '暂无域名'));
  } else if (text === '/expiring') {
    const domains = await getList(env, 'domains');
    const exp = domains.filter(d => daysUntil(d.expiryDate) <= 30).sort((a, b) => daysUntil(a.expiryDate) - daysUntil(b.expiryDate));
    const lines = exp.map(d => statusEmoji(daysUntil(d.expiryDate)) + ' `' + d.name + '` — ' + daysLeft(d.expiryDate)).join('\n');
    await tgSend(c.botToken, chatId, exp.length ? '⏰ *30天内到期*\n\n' + lines : '✅ 30天内无到期域名');
  } else if (text === '/check') {
    await runDailyCheck(env);
    await tgSend(c.botToken, chatId, '✅ 检查完成');
  }
  return jsonRes({ ok: true });
}

async function runDailyCheck(env) {
  const c = JSON.parse(await kvGet(env, 'telegram_config', '{}'));
  if (!c.botToken || !c.chatId) return;
  const today = new Date().toDateString();
  if (await kvGet(env, 'last_check', '') === today) return;
  await kvPut(env, 'last_check', today);
  const domains = await getList(env, 'domains');
  const notify = domains.filter(d => {
    const days = daysUntil(d.expiryDate);
    return (d.reminderDays || [1, 7, 30]).includes(days) || days < 0;
  });
  if (!notify.length) return;
  const lines = notify.map(d => {
    const days = daysUntil(d.expiryDate);
    const e = days < 0 ? '🔴' : days <= 1 ? '🆘' : days <= 7 ? '🟠' : '🟡';
    return e + ' `' + d.name + '` — ' + (days < 0 ? '已过期 ' + Math.abs(days) + ' 天' : days + ' 天后到期') + '\n   注册商: ' + (d.registrar || '未知');
  }).join('\n\n');
  await tgSend(c.botToken, c.chatId, '⚠️ *域名续约提醒*\n\n' + lines);
}

async function tgSend(token, chatId, text) {
  if (!token) return;
  await fetch('https://api.telegram.org/bot' + token + '/sendMessage', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ chat_id: chatId, text, parse_mode: 'Markdown' }),
  });
}

// ─── 工具函数 ─────────────────────────────────────────────────────────────────

function daysUntil(dateStr) {
  if (!dateStr) return 9999;
  const exp = new Date(dateStr), now = new Date();
  exp.setHours(0, 0, 0, 0); now.setHours(0, 0, 0, 0);
  return Math.round((exp - now) / 86400000);
}

function daysLeft(dateStr) {
  const d = daysUntil(dateStr);
  if (d === 9999) return '未填写';
  if (d < 0) return '已过期 ' + Math.abs(d) + ' 天';
  return d + ' 天后到期';
}

function statusEmoji(d) { return d < 0 ? '🔴' : d <= 7 ? '🟠' : d <= 30 ? '🟡' : '🟢'; }
function jsonRes(data, status = 200) { return new Response(JSON.stringify(data), { status, headers: { 'Content-Type': 'application/json' } }); }

